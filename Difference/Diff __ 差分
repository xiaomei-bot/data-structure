#include<iostream>
#include<vector>
using namespace std;
vector<int>a;
vector<int>d;
void initDiff(int n)
{
	d.resize(n + 1);
	for (int i = 1; i <= n; i++)
	{
		d[i] = a[i] - a[i - 1];
	}
}
void rangeAdd(int l, int r, int k)
{
	d[l] += k;
	d[r + 1] -= k;
}
void getResult(int n)
{
	for (int i = 1; i <= n; i++)
	{
		a[i] = a[i - 1] + d[i];
	}
}
int main()
{
	int n;
	cin >> n;
	a.resize(n + 1);
	for (int i = 1; i <= n; i++) cin >> a[i];
	initDiff(n);
	int l, r, k;
	cin >> l >> r >> k;
	rangeAdd(l, r, k);
	getResult(n);
	for (int i = 1; i <= n;i++)cout << a[i] << ' ';
	return 0;
}
