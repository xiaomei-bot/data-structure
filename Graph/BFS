#include<iostream>
#include<queue>
#include<vector>
using namespace std;
int dir[4][2] = { 1,0,0,1,-1,0,0,-1 };
void bfs(vector<vector<char>>& g, vector<vector<bool>>& visited, int x, int y)
{
	queue<pair<int,int>>q;
	visited[x][y] = true;
	q.push({ x,y });
	while (!q.empty())
	{
		pair<int, int>cur;
		cur = q.front();
		q.pop();
		int curx = cur.first;
		int cury = cur.second;
		for (int i = 0; i < 4; i++)
		{
			int nextx = curx + dir[i][0]; 
			int nexty = cury + dir[i][1]; 
			if (nextx < 0 || nextx >= g.size() || nexty < 0 || nexty >= g[0].size()) continue; 
			if (!visited[nextx][nexty]) 
			{ 
				q.push({ nextx, nexty }); 
				visited[nextx][nexty] = true;
			}		
		}
	}

}
