#include<iostream>
#include<vector>
#include<algorithm>
#include<random>
using namespace std;
bool IsSorted(const vector<int>& v)
{
	for (int i = 1; i < v.size(); i++)
	{
		if (v[i] < v[i - 1]) return false;
	}
	return true;
}
vector<int>thanosSort(vector<int>v)
{
	if (IsSorted(v) || v.empty()) return v;
	static mt19937 rng(random_device{}());
	shuffle(v.begin(), v.end(), rng);
	vector<int>survivors(v.begin(), v.begin() + v.size() / 2);
	cout << "After Thanos snapped his fingers, there were" << endl;
	for (int x : survivors) cout << x << ' ';
	cout << endl;
	return thanosSort(survivors);
}
int main()
{
	int n;
	cout << "There are n people:" << endl;
	cin >> n;
	vector<int>v(n);
	cout << "These people are" << endl;
	for (int i = 0; i < n; i++)
	{
		cin >> v[i];
	}
	auto res = thanosSort(v);
	cout << "The last survivor:" << endl;
	for (int x : res) cout << x << ' ';
	return 0;
}
