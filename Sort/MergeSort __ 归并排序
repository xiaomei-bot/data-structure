#include<iostream>
using namespace std;
void merge(int a[], int l, int mid, int r)
{
	int* temp = new int[r - l + 1];
	int i = l; int j = mid + 1; int k = 0;
	while (i <= mid && j <= r)
	{
		if (a[i] <= a[j]) temp[k++] = a[i++];
		else temp[k++] = a[j++];
	}
	while (i <= mid) temp[k++] = a[i++];
	while (j <= r) temp[k++] = a[j++];
	for (int b = 0; b < k; b++) a[l + b] = temp[b];
	delete[]temp;
}
void mergeSort(int a[], int l, int r)
{
	if (l >= r) return;
	int mid = l + (r - l) / 2;
	mergeSort(a, l, mid);
	mergeSort(a, mid + 1, r);
	merge(a, l, mid, r);
}
int main()
{
	int n;
	cin >> n;
	int* a = new int[n];
	for (int i = 0; i < n; i++) cin >> a[i];
	mergeSort(a, 0, n - 1);
	for (int i = 0; i < n; i++) cout << a[i] << ' ';
	delete[]a;
	return 0;
}
