#include<iostream>
#include<vector>
#include<random>
using namespace std;
bool IsSorted(const vector<int>& v)
{
	for (int i = 1; i < v.size(); i++)
	{
		if (v[i] < v[i - 1]) return false;
	}
	return true;
}

int main()
{
	int n;
	cout << "输入个数：" << endl;
	cin >> n;
	vector<int>v(n);
	cout << "这些数分别为：" << endl;
	for (int i = 0; i < n; i++)
	{
		cin >> v[i];
	}
